<section class="section">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="text-center mb-5">
          <h3 class="mb-3 fw-semibold">Frequently Asked Questions</h3>
          <p class="text-muted mb-4 ff-secondary">
            If you cannot find an answer in our FAQ, contact us—we will respond shortly.
          </p>
          <div class="d-flex flex-wrap gap-2 justify-content-center">
            <a href="#contact" class="btn btn-primary rounded-pill"><i class="ri-mail-line me-2"></i>Email Us</a>
            <a href="#contact" class="btn btn-info rounded-pill"><i class="ri-twitter-line me-2"></i>Send a Tweet</a>
          </div>
        </div>
      </div>
    </div>
    <div class="row g-lg-5 g-4">
      <div class="col-lg-6">
        <div class="d-flex align-items-center mb-2">
          <i class="ri-question-line fs-4 text-success me-2"></i>
          <h5 class="mb-0 fw-semibold">General Questions</h5>
        </div>
        <div class="accordion accordion-border-box custom-accordion-border" id="faqGen">
          <div class="accordion-item">
            <h2 class="accordion-header"><button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#g1">What personal information do you collect?</button></h2>
            <div id="g1" class="accordion-collapse collapse show" data-bs-parent="#faqGen">
              <div class="accordion-body ff-secondary small">We collect basic information such as name, email, phone, and account credentials. We may also collect location, IP, and device data for security and personalization.</div>
            </div>
          </div>
          <div class="accordion-item">
            <h2 class="accordion-header"><button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#g2">Do you store my financial information?</button></h2>
            <div id="g2" class="accordion-collapse collapse" data-bs-parent="#faqGen">
              <div class="accordion-body ff-secondary small">For paid features, payment details may be collected through a secure third-party processor. We do not store full card data on our servers.</div>
            </div>
          </div>
          <div class="accordion-item">
            <h2 class="accordion-header"><button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#g3">How is my information secured?</button></h2>
            <div id="g3" class="accordion-collapse collapse" data-bs-parent="#faqGen">
              <div class="accordion-body ff-secondary small">We use SSL/TLS, firewalls, and secure authentication. Payments use PCI-DSS compliant gateways.</div>
            </div>
          </div>
          <div class="accordion-item">
            <h2 class="accordion-header"><button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#g4">Is my data shared with third parties?</button></h2>
            <div id="g4" class="accordion-collapse collapse" data-bs-parent="#faqGen">
              <div class="accordion-body ff-secondary small">We do not sell your data. We only share with trusted partners necessary to operate the platform, under strict agreements.</div>
            </div>
          </div>
          <div class="accordion-item">
            <h2 class="accordion-header"><button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#g5">How can I update or delete my data?</button></h2>
            <div id="g5" class="accordion-collapse collapse" data-bs-parent="#faqGen">
              <div class="accordion-body ff-secondary small">Update details in account settings. For deletion requests, contact our support team.</div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="d-flex align-items-center mb-2">
          <i class="ri-shield-keyhole-line fs-4 text-success me-2"></i>
          <h5 class="mb-0 fw-semibold">Privacy &amp; Security</h5>
        </div>
        <div class="accordion accordion-border-box custom-accordion-border" id="faqPriv">
          <div class="accordion-item">
            <h2 class="accordion-header"><button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#p1">What if there is a data breach?</button></h2>
            <div id="p1" class="accordion-collapse collapse show" data-bs-parent="#faqPriv">
              <div class="accordion-body ff-secondary small">We investigate immediately, notify affected users, and take steps to contain and prevent recurrence.</div>
            </div>
          </div>
          <div class="accordion-item">
            <h2 class="accordion-header"><button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#p2">Can I opt out of data collection?</button></h2>
            <div id="p2" class="accordion-collapse collapse" data-bs-parent="#faqPriv">
              <div class="accordion-body ff-secondary small">You can control sharing in settings. Some opt-outs may limit functionality.</div>
            </div>
          </div>
          <div class="accordion-item">
            <h2 class="accordion-header"><button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#p3">Is financial data used for marketing?</button></h2>
            <div id="p3" class="accordion-collapse collapse" data-bs-parent="#faqPriv">
              <div class="accordion-body ff-secondary small">No. Sensitive financial data is not shared with marketing or analytics platforms.</div>
            </div>
          </div>
          <div class="accordion-item">
            <h2 class="accordion-header"><button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#p4">Do you use cookies?</button></h2>
            <div id="p4" class="accordion-collapse collapse" data-bs-parent="#faqPriv">
              <div class="accordion-body ff-secondary small">Yes, to improve experience and services. You can manage cookies in your browser.</div>
            </div>
          </div>
          <div class="accordion-item">
            <h2 class="accordion-header"><button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#p5">Who do I contact for privacy concerns?</button></h2>
            <div id="p5" class="accordion-collapse collapse" data-bs-parent="#faqPriv">
              <div class="accordion-body ff-secondary small">Contact our Privacy Officer at privacy@varnarc.com.</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

