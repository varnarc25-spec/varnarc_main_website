<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= typeof title !== 'undefined' ? title : 'Varnarc' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/@mdi/font@7.4.47/css/materialdesignicons.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
    />
    <link rel="stylesheet" href="/css/landing.css" />
    <style>
      :root {
        --bs-primary: #405189;
        --bs-link-color: #405189;
      }
    </style>
  </head>
  <body class="landing-page">
    <nav class="navbar navbar-expand-lg navbar-landing fixed-top" id="navbar">
      <div class="container">
        <a class="navbar-brand d-flex align-items-center" href="/home">
          <img
            src="/assets/images/logo-dark.png"
            class="card-logo card-logo-dark"
            alt="Varnarc"
            height="22"
          />
          <img
            src="/assets/images/logo-light.png"
            class="card-logo card-logo-light"
            alt="Varnarc"
            height="22"
          />
        </a>
        <button
          class="navbar-toggler py-0 fs-20 text-body border-0"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarSupportedContent"
          aria-controls="navbarSupportedContent"
          aria-expanded="false"
          aria-label="Toggle navigation"
        >
          <i class="mdi mdi-menu"></i>
        </button>
        <div class="collapse navbar-collapse" id="navbarSupportedContent">
          <ul class="navbar-nav mx-auto mt-2 mt-lg-0" id="navbar-example">
            <li class="nav-item">
              <a class="nav-link" href="#hero" data-scroll>Home</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="#services" data-scroll>Services</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="#tools" data-scroll>Tools</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="#features" data-scroll>Features</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="#plans" data-scroll>Plans</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="#reviews" data-scroll>Reviews</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="#contact" data-scroll>Contact</a>
            </li>
          </ul>
          <div class="d-flex align-items-center gap-2 ms-lg-2">
            <a
              class="btn btn-link fw-medium text-decoration-none text-dark px-2"
              href="#contact"
              >Sign in</a
            >
            <a class="btn btn-primary" href="#plans">Sign Up</a>
          </div>
        </div>
      </div>
    </nav>

    <div
      class="vertical-overlay"
      data-bs-toggle="collapse"
      data-bs-target="#navbarSupportedContent"
    ></div>

    <div class="layout-wrapper landing pt-5">
      <div style="height: 56px" aria-hidden="true"></div>
